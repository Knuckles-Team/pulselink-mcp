{
  "mcpServers": {
    "pulselink-mcp": {
      "command": "uv",
      "args": [
        "run",
        "pulselink-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "PULSELINK_MCP_SSL_VERIFY": "<YOUR_PULSELINK_MCP_SSL_VERIFY>",
        "PULSETOOL": "True"
      }
    }
  }
}
