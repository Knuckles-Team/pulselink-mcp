{
  "mcpServers": {
    "pulselink-mcp": {
      "command": "uv",
      "args": [
        "run",
        "pulselink-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "PULSETOOL": "True",
        "XAI_BASE_URL": "https://api.x.ai/v1",
        "XAI_SEARCH_MODEL": "grok-4.3"
      }
    }
  }
}
